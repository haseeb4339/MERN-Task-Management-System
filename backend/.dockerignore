# Ignore node_modules and frontend build
node_modules/
frontend/node_modules/
frontend/build/

# Ignore sensitive files
.env
*.env

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore log files
*.log

# Ignore package-lock files (if you want to avoid conflicts)
package-lock.json
frontend/package-lock.json
backend/package-lock.json

# Ignore Git and Docker files
.git/
.gitignore
.dockerignore

# Ignore IDE and editor files
.vscode/
.idea/

# Ignore test and coverage files
coverage/
test/
tests/

# Ignore build output
dist/
build/

# Ignore Dockerfile (if you want to keep your build context clean)
Dockerfile